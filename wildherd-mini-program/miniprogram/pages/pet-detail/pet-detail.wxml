<!-- pages/pet-detail/pet-detail.wxml -->
<view class="page-container">
  <block wx:if="{{loading}}">
    <view class="loading-state">
      <van-loading size="24px">加载中...</van-loading>
    </view>
  </block>

  <block wx:elif="{{pet}}">
    <!-- 头部信息 -->
    <view class="pet-header">
      <view class="pet-image" bindtap="previewImage">
        <image wx:if="{{pet.imageUrl}}" src="{{pet.imageUrl}}" mode="aspectFill" />
        <view wx:else class="pet-avatar-lg">{{pet.name[0]}}</view>
      </view>
      <view class="pet-title">
        <text class="pet-name">{{pet.name}}</text>
        <text class="pet-species">{{pet.speciesChinese || pet.species}}</text>
        <view class="pet-tags">
          <van-tag type="{{pet.gender === 'male' ? 'blue' : 'pink'}}" size="medium">
            {{pet.gender === 'male' ? '公' : pet.gender === 'female' ? '母' : '未知'}}
          </van-tag>
          <van-tag type="success" size="medium" class="ml-10">
            {{pet.breedingStatus === 'available' ? '可繁殖' :
              pet.breedingStatus === 'bred' ? '已繁殖' :
              pet.breedingStatus === 'immature' ? '未成年' : '休养中'}}
          </van-tag>
        </view>
      </view>
    </view>

    <!-- 标签页 -->
    <van-tabs active="{{activeTab}}" bind:change="onTabChange">
      <!-- 基本信息 -->
      <van-tab title="基本信息" name="info">
        <view class="card">
          <van-cell-group>
            <van-cell title="体重" value="{{pet.weight ? pet.weight + 'g' : '-'}}" />
            <van-cell title="体长" value="{{pet.length ? pet.length + 'cm' : '-'}}" />
            <van-cell title="出生日期" value="{{pet.birthDate || '-'}}" />
            <van-cell title="入舍日期" value="{{pet.acquisitionDate || '-'}}" />
          </van-cell-group>
          <view class="notes-section" wx:if="{{pet.notes}}">
            <view class="notes-title">备注</view>
            <text class="text-secondary">{{pet.notes}}</text>
          </view>
        </view>
      </van-tab>

      <!-- 喂食记录 -->
      <van-tab title="喂食记录" name="feeding">
        <view class="tab-actions">
          <van-button type="primary" size="small" bindtap="goToAddFeeding">
            + 添加记录
          </van-button>
        </view>
        <view class="record-list">
          <block wx:if="{{feedingRecords.length > 0}}">
            <view wx:for="{{feedingRecords}}" wx:key="_id" class="record-item">
              <view class="record-icon feeding-icon">
                <van-icon name="shopping-o" />
              </view>
              <view class="record-content">
                <view class="record-title">{{item.foodType}}</view>
                <view class="record-meta">
                  <text wx:if="{{item.foodAmount}}">{{item.foodAmount}}g</text>
                  <text class="ml-20">{{item.feedingTime}}</text>
                </view>
                <view class="record-notes text-secondary" wx:if="{{item.notes}}">
                  {{item.notes}}
                </view>
              </view>
            </view>
          </block>
          <view wx:else class="empty-tab">
            <text>暂无喂食记录</text>
          </view>
        </view>
      </van-tab>

      <!-- 健康记录 -->
      <van-tab title="健康记录" name="health">
        <view class="tab-actions">
          <van-button type="primary" size="small" bindtap="goToAddHealth">
            + 添加记录
          </van-button>
        </view>
        <view class="record-list">
          <block wx:if="{{healthRecords.length > 0}}">
            <view wx:for="{{healthRecords}}" wx:key="_id" class="record-item">
              <view class="record-icon health-icon">
                <van-icon name="plus" />
              </view>
              <view class="record-content">
                <view class="record-title">{{item.recordDate}}</view>
                <view class="record-meta">
                  <text wx:if="{{item.weight}}">体重: {{item.weight}}g</text>
                  <text wx:if="{{item.length}}" class="ml-20">体长: {{item.length}}cm</text>
                </view>
                <view class="record-tags">
                  <van-tag type="{{item.status === 'normal' ? 'success' : 'warning'}}" size="small">
                    {{item.status === 'normal' ? '正常' : '异常'}}
                  </van-tag>
                  <van-tag type="default" size="small" class="ml-10" wx:if="{{item.defecation}}">
                    排便: {{item.defecation}}
                  </van-tag>
                </view>
                <view class="record-notes text-secondary" wx:if="{{item.notes}}">
                  {{item.notes}}
                </view>
              </view>
            </view>
          </block>
          <view wx:else class="empty-tab">
            <text>暂无健康记录</text>
          </view>
        </view>
      </van-tab>
    </van-tabs>

    <!-- 底部操作 -->
    <view class="bottom-actions">
      <van-button type="default" size="small" bindtap="goToEdit">编辑</van-button>
      <van-button type="danger" size="small" plain bindtap="confirmDelete">删除</van-button>
    </view>
  </block>

  <block wx:else>
    <view class="empty-state">
      <text>宠物不存在</text>
    </view>
  </block>
</view>
