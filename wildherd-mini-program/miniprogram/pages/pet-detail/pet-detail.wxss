/* pages/pet-detail/pet-detail.wxss */

/* 头部信息 */
.pet-header {
  display: flex;
  background: linear-gradient(135deg, #4CAF50 0%, #81C784 100%);
  color: white;
  padding: 60rpx 40rpx;
}

.pet-image {
  width: 180rpx;
  height: 180rpx;
  margin-right: 40rpx;
}

.pet-image image,
.pet-avatar-lg {
  width: 100%;
  height: 100%;
  border-radius: 24rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.pet-avatar-lg {
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 72rpx;
}

.pet-title {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.pet-name {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.pet-species {
  font-size: 28rpx;
  opacity: 0.85;
  margin-bottom: 16rpx;
}

.pet-tags {
  display: flex;
}

/* 备注区域 */
.notes-section {
  margin-top: 30rpx;
  padding-top: 30rpx;
  border-top: 1rpx solid var(--border-color);
}

.notes-title {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

/* Tab 操作区 */
.tab-actions {
  padding: 20rpx;
  display: flex;
  justify-content: flex-end;
}

/* 记录列表 */
.record-list {
  padding: 0 20rpx;
}

.record-item {
  display: flex;
  background: white;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.record-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.feeding-icon {
  background: #E8F5E9;
  color: #4CAF50;
}

.health-icon {
  background: #E3F2FD;
  color: #2196F3;
}

.record-content {
  flex: 1;
}

.record-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.record-meta {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.record-tags {
  display: flex;
  margin-bottom: 8rpx;
}

.record-notes {
  font-size: 26rpx;
  margin-top: 8rpx;
}

.empty-tab {
  text-align: center;
  padding: 60rpx;
  color: var(--text-placeholder);
}

/* 底部操作 */
.bottom-actions {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  padding: 30rpx;
  background: white;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

/* 加载状态 */
.loading-state {
  display: flex;
  justify-content: center;
  padding: 200rpx;
}
