<!-- pages/health/health.wxml -->
<view class="page-container">
  <view class="filter-bar" wx:if="{{pets.length > 0}}">
    <text class="filter-label">筛选爬宠：</text>
    <picker mode="selector" range="{{pets}}" range-key="name" value="0" bindchange="onPetChange">
      <view class="filter-value">
        {{selectedPetId ? (pets.find(p => p._id === selectedPetId)?.name || '全部') : '全部'}}
        <van-icon name="arrow-down" />
      </view>
    </picker>
  </view>

  <view class="record-list">
    <block wx:if="{{loading}}">
      <view class="loading-state"><van-loading size="24px">加载中...</van-loading></view>
    </block>
    <block wx:elif="{{records.length > 0}}">
      <view wx:for="{{records}}" wx:key="_id" class="record-card">
        <view class="record-main">
          <view class="record-icon health-icon"><van-icon name="plus" /></view>
          <view class="record-info">
            <view class="record-title">{{item.recordDate}}</view>
            <view class="record-meta">
              <text wx:if="{{item.weight}}">体重: {{item.weight}}g</text>
              <text wx:if="{{item.length}}" class="ml-20">体长: {{item.length}}cm</text>
            </view>
            <view class="record-tags">
              <van-tag type="{{item.status === 'normal' ? 'success' : 'warning'}}" size="small">
                {{item.status === 'normal' ? '正常' : '异常'}}
              </van-tag>
              <van-tag type="default" size="small" class="ml-10" wx:if="{{item.defecation}}">
                {{item.defecation === 'normal' ? '排便正常' : item.defecation === 'abnormal' ? '排便异常' : '便秘'}}
              </van-tag>
            </view>
          </view>
        </view>
        <van-icon name="delete-o" class="delete-btn" bindtap="deleteRecord" data-id="{{item._id}}" />
      </view>
    </block>
    <block wx:else>
      <view class="empty-state">
        <image src="/assets/icons/empty-record.png" mode="aspectFit" />
        <text>暂无健康记录</text>
        <van-button type="primary" size="small" class="mt-20" bindtap="openAddModal">添加记录</van-button>
      </view>
    </block>
  </view>

  <view class="fab" bindtap="openAddModal" wx:if="{{records.length > 0}}">+</view>

  <van-popup show="{{showAddModal}}" position="bottom" round bind:close="closeModal">
    <view class="add-modal">
      <view class="modal-header">
        <text>添加健康记录</text>
        <van-icon name="cross" bindtap="closeModal" />
      </view>
      <view class="modal-body">
        <van-cell-group>
          <van-cell title="爬宠">
            <picker mode="selector" range="{{pets}}" range-key="name" value="0" bindchange="onFormChange" data-field="reptileId">
              <view>{{pets.find(p => p._id === formData.reptileId)?.name || '请选择'}}</view>
            </picker>
          </van-cell>
          <van-cell title="记录日期">
            <picker mode="date" value="{{formData.recordDate}}" bindchange="onFormChange" data-field="recordDate">
              <view>{{formData.recordDate}}</view>
            </picker>
          </van-cell>
          <van-field label="体重(g)" type="digit" placeholder="可选" value="{{formData.weight}}" data-field="weight" bind:change="onFormChange" />
          <van-field label="体长(cm)" type="digit" placeholder="可选" value="{{formData.length}}" data-field="length" bind:change="onFormChange" />
          <van-cell title="健康状态">
            <van-radio-group value="{{formData.status}}" bind:change="onFormChange" data-field="status">
              <van-radio name="normal" shape="square">正常</van-radio>
              <van-radio name="abnormal" shape="square" class="ml-20">异常</van-radio>
            </van-radio-group>
          </van-cell>
          <van-cell title="排便状态">
            <van-radio-group value="{{formData.defecation}}" bind:change="onFormChange" data-field="defecation">
              <van-radio name="normal" shape="square">正常</van-radio>
              <van-radio name="abnormal" shape="square" class="ml-10">异常</van-radio>
              <van-radio name="constipated" shape="square" class="ml-10">便秘</van-radio>
            </van-radio-group>
          </van-cell>
          <van-field label="备注" placeholder="可选" value="{{formData.notes}}" data-field="notes" bind:change="onFormChange" />
        </van-cell-group>
        <van-button type="primary" size="large" class="mt-20" bindtap="submitRecord">保存</van-button>
      </view>
    </view>
  </van-popup>
</view>
