/* pages/encyclopedia/encyclopedia.wxss */

.search-bar { background: white; padding: 10rpx 0; }

.category-scroll { background: white; white-space: nowrap; padding: 20rpx; }

.category-list { display: inline-flex; }

.category-item {
  display: inline-block;
  padding: 16rpx 32rpx;
  margin-right: 20rpx;
  background: var(--bg-color);
  border-radius: 32rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
}

.category-item.active {
  background: var(--primary-color);
  color: white;
}

.species-list { padding: 20rpx; }

.species-card {
  display: flex;
  align-items: center;
  background: white;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.species-info { flex: 1; }

.species-name { font-size: 32rpx; font-weight: bold; margin-bottom: 8rpx; }

.species-en-name { font-size: 26rpx; margin-bottom: 12rpx; }

.species-meta { display: flex; align-items: center; }

.species-arrow { color: var(--text-placeholder); }

.load-more { text-align: center; padding: 30rpx; }

.loading-state { display: flex; justify-content: center; padding: 100rpx; }
