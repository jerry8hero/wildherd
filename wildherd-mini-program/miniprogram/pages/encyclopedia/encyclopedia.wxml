<!-- pages/encyclopedia/encyclopedia.wxml -->
<view class="page-container">
  <!-- 搜索框 -->
  <view class="search-bar">
    <van-search value="{{searchKeyword}}" placeholder="搜索物种..." bind:search="onSearch" />
  </view>

  <!-- 分类选择 -->
  <scroll-view scroll-x class="category-scroll">
    <view class="category-list">
      <view
        wx:for="{{categories}}"
        wx:key="id"
        class="category-item {{selectedCategory === item.id ? 'active' : ''}}"
        bindtap="onCategoryChange"
        data-category="{{item.id}}"
      >
        <text>{{item.name}}</text>
      </view>
    </view>
  </scroll-view>

  <!-- 物种列表 -->
  <view class="species-list">
    <block wx:if="{{loading && speciesList.length === 0}}">
      <view class="loading-state"><van-loading size="24px">加载中...</van-loading></view>
    </block>
    <block wx:elif="{{speciesList.length > 0}}">
      <view
        wx:for="{{speciesList}}"
        wx:key="_id"
        class="species-card"
        bindtap="goToSpeciesDetail"
        data-id="{{item._id}}"
      >
        <view class="species-info">
          <view class="species-name">{{item.nameChinese}}</view>
          <view class="species-en-name text-secondary">{{item.nameEnglish}}</view>
          <view class="species-meta">
            <van-tag type="{{item.difficulty <= 2 ? 'success' : item.difficulty <= 3 ? 'warning' : 'danger'}}" size="small">
              难度 {{item.difficulty}}/5
            </van-tag>
            <text class="ml-10 text-secondary font-24">寿命 {{item.lifespan}}年</text>
          </view>
        </view>
        <van-icon name="arrow" class="species-arrow" />
      </view>
    </block>
    <block wx:else>
      <view class="empty-state">
        <text>暂无物种数据</text>
      </view>
    </block>

    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{speciesList.length > 0 && !loading}}">
      <text wx:if="{{hasMore}}" class="text-secondary">上拉加载更多...</text>
      <text wx:else class="text-secondary">没有更多了</text>
    </view>
  </view>
</view>
