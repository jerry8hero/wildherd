<!-- pages/index/index.wxml -->
<view class="page-container">
  <!-- 天气卡片 -->
  <view class="weather-card" bindtap="refreshWeather">
    <block wx:if="{{weather && weather.now}}">
      <view class="weather-main">
        <text class="weather-temp">{{weather.now.temp}}°</text>
        <text class="weather-text">{{weather.now.text}}</text>
      </view>
      <view class="weather-detail">
        <text>湿度 {{weather.now.humidity}}%</text>
        <text class="ml-20">风速 {{weather.now.windSpeed}} km/h</text>
      </view>
      <view class="weather-advice">
        <text wx:if="{{weather.now.feelsLike}}">体感温度 {{weather.now.feelsLike}}°</text>
      </view>
    </block>
    <block wx:elif="{{hasLocation}}">
      <text class="text-secondary">正在加载天气...</text>
    </block>
    <block wx:else>
      <text class="text-secondary">点击开启位置权限获取天气</text>
    </block>
  </view>

  <!-- 快捷入口 -->
  <view class="quick-actions">
    <view class="action-item" bindtap="goToFeeding">
      <image src="/assets/icons/feeding.png" mode="aspectFit" />
      <text>喂食记录</text>
    </view>
    <view class="action-item" bindtap="goToHealth">
      <image src="/assets/icons/health.png" mode="aspectFit" />
      <text>健康记录</text>
    </view>
  </view>

  <!-- 宠物列表标题 -->
  <view class="section-header">
    <text class="section-title">我的爬宠</text>
    <view class="add-btn" bindtap="goToAddPet">+ 添加</view>
  </view>

  <!-- 宠物列表 -->
  <view class="pet-list">
    <block wx:if="{{loading}}">
      <view class="loading-state">
        <van-loading size="24px">加载中...</van-loading>
      </view>
    </block>
    <block wx:elif="{{pets.length > 0}}">
      <view
        wx:for="{{pets}}"
        wx:key="_id"
        class="pet-card"
        bindtap="goToPetDetail"
        data-id="{{item._id}}"
      >
        <view class="pet-image">
          <image
            wx:if="{{item.imageUrl}}"
            src="{{item.imageUrl}}"
            mode="aspectFill"
          />
          <view wx:else class="pet-avatar">{{item.name[0]}}</view>
        </view>
        <view class="pet-info">
          <view class="pet-name">{{item.name}}</view>
          <view class="pet-species">{{item.speciesChinese || item.species}}</view>
          <view class="pet-meta">
            <van-tag type="{{item.gender === 'male' ? 'blue' : 'pink'}}" size="small">
              {{item.gender === 'male' ? '公' : item.gender === 'female' ? '母' : '未知'}}
            </van-tag>
            <text class="ml-10 text-secondary font-24" wx:if="{{item.weight}}">
              {{item.weight}}g
            </text>
          </view>
        </view>
        <van-icon name="arrow" class="pet-arrow" />
      </view>
    </block>
    <block wx:else>
      <view class="empty-state">
        <image src="/assets/icons/empty-pet.png" mode="aspectFit" />
        <text>还没有爬宠，点击添加一只吧</text>
        <van-button type="primary" size="small" class="mt-20" bindtap="goToAddPet">
          添加爬宠
        </van-button>
      </view>
    </block>
  </view>
</view>
